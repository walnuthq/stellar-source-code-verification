{
  "name": "api-registry",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "default": "./dist/verify.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "16.0.1",
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-rc.3",
    "express": "5.2.1",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "drizzle-kit": "1.0.0-rc.3",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
