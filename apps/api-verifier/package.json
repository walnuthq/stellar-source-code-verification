{
  "name": "api-verifier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "16.0.1",
    "dotenv": "17.4.2",
    "drizzle-orm": "1.0.0-rc.3",
    "express": "5.1.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/express": "5.0.1",
    "@types/node": "24.13.2",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "drizzle-kit": "1.0.0-rc.3",
    "supertest": "7.2.2",
    "tsx": "4.19.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
