# Postgres connection (matches repo-root docker-compose.yml; host port 5434 to
# avoid colliding with other local postgres containers already on 5432/5433)
DATABASE_URL=postgres://verifier:verifier@localhost:5434/verifier

# HTTP server port
PORT=3000

# Identity this verifier publishes in source_code_verifications[].verifier
VERIFIER_NAME=Example Verification Service
VERIFIER_URL=https://verify.example.com
